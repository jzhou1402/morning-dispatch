# ── No key needed ─────────────────────────────────────────────────
# Hacker News, Wikipedia, Open Trivia DB — just work out of the box.

# ── Free API keys ──────────────────────────────────────────────────
OPENWEATHERMAP_KEY=your_key_here
OPENWEATHERMAP_CITY=San Francisco

NASA_API_KEY=your_key_here

WORDNIK_API_KEY=your_key_here

# ── Google (Gmail + Calendar share one credential file) ────────────
# Place google_credentials.json in the project root after downloading
# from Google Cloud Console (see README for setup steps).

# ── Reddit (no API key needed — uses RSS) ──────────────────────────
REDDIT_SUBREDDITS=technology,science,worldnews

# ── Spotify ────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Webull ─────────────────────────────────────────────────────────
WEBULL_USERNAME=your_email
WEBULL_PASSWORD=your_password
WEBULL_TRADING_PIN=your_6digit_pin

# ── Anthropic (Op-Ed generation) ───────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

